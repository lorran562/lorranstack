# =============================================
# LorranStack Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no Git
# =============================================

# Porta do servidor (Railway/Render define automaticamente)
PORT=3000

# Ambiente
NODE_ENV=production

# ── Banco de Dados (Supabase) ──────────────────
# Copie de: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.[ref]:[senha]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ── Autenticação ───────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SECRETA_FORTE_COM_64_CHARS
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────
# URL do seu frontend no Vercel (sem barra final)
FRONTEND_URL=https://lorranstack.vercel.app

# ── Supabase (para Storage de imagens futuramente) ─
SUPABASE_URL=https://jkgrmlfqgprcwfooovkx.supabase.co
SUPABASE_ANON_KEY=coloque_sua_anon_key_aqui
