{
  "version": 2,
  "name": "lorranstack",
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/supabase.js",
      "dest": "/frontend/supabase.js"
    },
    {
      "src": "/config.js",
      "dest": "/frontend/config.js"
    },
    {
      "src": "/explore.html",
      "dest": "/frontend/explore.html"
    },
    {
      "src": "/saas.html",
      "dest": "/frontend/saas.html"
    },
    {
      "src": "/collections.html",
      "dest": "/frontend/collections.html"
    },
    {
      "src": "/ranking.html",
      "dest": "/frontend/ranking.html"
    },
    {
      "src": "/dashboard.html",
      "dest": "/frontend/dashboard.html"
    },
    {
      "src": "/admin.html",
      "dest": "/frontend/admin.html"
    },
    {
      "src": "/creator.html",
      "dest": "/frontend/creator.html"
    },
    {
      "src": "/hero-section.html",
      "dest": "/frontend/hero-section.html"
    },
    {
      "src": "/explore",
      "dest": "/frontend/explore.html"
    },
    {
      "src": "/saas",
      "dest": "/frontend/saas.html"
    },
    {
      "src": "/collections",
      "dest": "/frontend/collections.html"
    },
    {
      "src": "/ranking",
      "dest": "/frontend/ranking.html"
    },
    {
      "src": "/dashboard",
      "dest": "/frontend/dashboard.html"
    },
    {
      "src": "/admin",
      "dest": "/frontend/admin.html"
    },
    {
      "src": "/creator",
      "dest": "/frontend/creator.html"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}