{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/create-checkout",
      "dest": "/api/create-checkout.js"
    },
    {
      "src": "/api/stripe-webhook",
      "dest": "/api/stripe-webhook.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/stripe-checkout.js",
      "dest": "/public/stripe-checkout.js"
    },
    {
      "src": "/supabase.js",
      "dest": "/public/supabase.js"
    },
    {
      "src": "/config.js",
      "dest": "/public/config.js"
    },
    {
      "src": "/index.html",
      "dest": "/public/index.html"
    },
    {
      "src": "/explore.html",
      "dest": "/public/explore.html"
    },
    {
      "src": "/produto.html",
      "dest": "/public/produto.html"
    },
    {
      "src": "/saas.html",
      "dest": "/public/saas.html"
    },
    {
      "src": "/pricing.html",
      "dest": "/public/pricing.html"
    },
    {
      "src": "/dashboard.html",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/collections.html",
      "dest": "/public/collections.html"
    },
    {
      "src": "/ranking.html",
      "dest": "/public/ranking.html"
    },
    {
      "src": "/admin.html",
      "dest": "/public/admin.html"
    },
    {
      "src": "/creator.html",
      "dest": "/public/creator.html"
    },
    {
      "src": "/pricing",
      "dest": "/public/pricing.html"
    },
    {
      "src": "/explore",
      "dest": "/public/explore.html"
    },
    {
      "src": "/dashboard",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/ranking",
      "dest": "/public/ranking.html"
    },
    {
      "src": "/contrato-freelancer.html",
      "dest": "/public/contrato-freelancer.html"
    },
    {
      "src": "/contrato-freelancer",
      "dest": "/public/contrato-freelancer.html"
    },
    {
      "src": "/logo-lorranstack.jpeg",
      "dest": "/public/logo-lorranstack.jpeg"
    },
    {
      "src": "/readme-generator",
      "dest": "/public/readme-generator.html"
    },
    {
      "src": "/readme-generator.html",
      "dest": "/public/readme-generator.html"
    },
    {
      "src": "/api/create-payment",
      "dest": "/api/create-payment.js"
    },
    {
      "src": "/api/payment-status",
      "dest": "/api/payment-status.js"
    },
    {
      "src": "/api/mp-webhook",
      "dest": "/api/mp-webhook.js"
    },
    {
      "src": "/checkout.js",
      "dest": "/public/checkout.js"
    },
    {
      "src": "/regex-dev",
      "dest": "/public/regex-dev.html"
    },
    {
      "src": "/regex-dev.html",
      "dest": "/public/regex-dev.html"
    },
    {
      "src": "/env-guard",
      "dest": "/public/env-guard.html"
    },
    {
      "src": "/env-guard.html",
      "dest": "/public/env-guard.html"
    },
    {
      "src": "/gitlog",
      "dest": "/public/gitlog.html"
    },
    {
      "src": "/gitlog.html",
      "dest": "/public/gitlog.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}